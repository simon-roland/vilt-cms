{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "jsx": "preserve",
        "types": ["vite/client"],
        "paths": {
            "@/*": ["./resources/js/*"],
            "@cms/*": ["./vendor/roland-solutions/cms/resources/js/*"]
        }
    },
    "include": ["resources/js/**/*"]
}
